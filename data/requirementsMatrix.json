        "issuing_authorities": [
          "State Ministry of Physical Planning",
          "Lagos State Physical Planning Authority",
          "LASPPPA",
          "Abuja Municipal Area Council",
          "Local Government Authority"
        ],
        "validity_months": 12,
        "mandatory": true
      },
      {
        "document_type": "coren_certificate",
        "label": "COREN Registration Certificate",
        "issuing_authorities": [
          "COREN",
