        "issuing_authorities": [
          "State Ministry of Physical Planning",
          "Lagos State Physical Planning Authority",
          "Abuja Municipal Area Council"
        ],
        "mandatory": true
      },
      {
        "document_type": "final_inspection_report",
        "label": "Final Inspection Report",
        "issuing_authorities": [
          "Building Control Authority",
          "State Ministry of Physical Planning"
        ],
        "mandatory": true
      },
      {
        "document_type": "structural_completion_certificate",
